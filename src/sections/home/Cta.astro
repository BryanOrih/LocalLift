---
import CtaSecurityDiagram from '../../../public/assets/homePage/cta-security-diagram.svg' 
import Smudge from "../../../public/assets/homePage/smudge.svg";
---
  <section class="cta-section" id="CTA-section">
    <div class="cta-inner">
      <div class="cta-content">
        <div class="section-heading-wrapper">
          <Smudge class="smudge smudge-cta" />

          <p class="cta-title">
            Ready to Get More Clients?
          </p>
        </div>

        <p>
          Let’s build a website that works for your business.
        </p>

        <button>Get Started</button>
      </div>

      <CtaSecurityDiagram class="cta-diagram" />
    </div>
  </section>


<style>

  p, ul {
	font-size: 18px;
  }

  .cta-diagram {
    height: fit-content;
    width: 45%;
    position: relative;
    max-width: 800px;
    display: none;
  }

  .cta-section {
    padding-top: 80px;
    padding-bottom: 80px;
    display: flex;
    flex-direction: column;
    gap: 40px;
    align-items: center;
  }



  .smudge {
    position: absolute;
    width: 300px;
  }


  .smudge-cta {
    bottom: 72px;
    right: 0;
    left: 16.25rem;
    transform: scale(1.1, 1.5);
    transform-origin: center;
  }



 

  .cta-inner {
    align-items: center;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-evenly;
  }

  .cta-content {
    display: flex;
    flex-direction: column;
    max-width: 700px;
    gap: 40px;
  }

  .cta-title {
    font-weight: 600;
    font-size: 72px;
    line-height: 1.25;
    position: sticky;
  }




  @media (min-width: 1280px) {
    .cta-inner {
      flex-direction: row;
    }


    .cta-content {
      width: 45%;
    }

    .cta-diagram {
      display: block;
    }
  }
<style/>