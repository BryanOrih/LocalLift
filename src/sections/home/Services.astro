---
import Smudge from "../../../public/assets/homePage/smudge.svg";

const services = [
  {
    title: "Website Design",
    description:
      "Custom-built websites designed to convert visitors into paying customers.",
    image:
      "https://media2.dev.to/dynamic/image/width=1080,height=1080,fit=cover,gravity=auto,format=auto/https://dev-to-uploads.s3.amazonaws.com/uploads/articles/zsyklljdugbnhl6silqo.jpg",
    alt: "coding-image",
  },
  {
    title: "Local SEO Optimization",
    description:
      "Get your business ranking higher on Google so customers can find you in your area.",
    image:
      "https://images.squarespace-cdn.com/content/5dac9a5dd63b2c7e6452e34a/1710792832829-1NXWBZM2K7KXFJ83UVIA/Screenshot+2024-03-18+at+4.13.50%E2%80%AFPM.png?content-type=image%2Fpng",
    alt: "SEO-image",
  },
  {
    title: "Booking System Setup",
    description:
      "We integrate tools like booking platforms to make scheduling easy for your clients.",
    image:
      "https://cdn2.psychologytoday.com/assets/styles/manual_crop_4_3_1200x900/public/teaser_image/blog_entry/2024-06/Calendar.jpg?itok=5g55vUZ1",
    alt: "Booking-image",
  },
  {
    title: "Content & Media Creation",
    description:
      "Professional photos and videos to help your brand stand out online.",
    image:
      "https://static.foxnews.com/foxnews.com/content/uploads/2025/06/1-how-to-move-photos-and-videos-off-of-a-phone.jpg",
    alt: "Content-and-Creation-image",
  },
];
---

<section id="Services-section">
  <div class="header-wrapper">
    <div>
      <Smudge class="smudge smudge-services" />
      <h2>What We Do</h2>
    </div>
    <p>
      Simple, effective digital solutions designed to help local businesses
      grow.
    </p>
  </div>
  <div class="grid">
    {
      services.map(({ image, title, description, alt }) => (
        <figure class="card">
          <img loading="lazy" class="service-image" src={image} alt={alt} />
          <figcaption>
            <h3>{title}</h3>
            <p>{description}</p>
          </figcaption>
        </figure>
      ))
    }
  </div>
</section>

<style>
  .header-wrapper {
    display: flex;
    flex-direction: column;
    gap: 20px;
    width: 100%;
    text-align: center;
    & div {
      position: relative;
      & svg {
        position: absolute;
        width: calc(var(--step-4) * 4.4);
        bottom: -5px;
        right: 0;
        left: 49%;
      }
      & h2 {
        text-align: center;
        font-size: var(--step-4);
        font-weight: 700;
        position: relative;
        margin: 0;
      }
    }
    & p {
      text-align: center;
    }
  }

  section {
    padding: min(80px, 10vw);
    display: flex;
    flex-direction: column;
    gap: 40px;
    align-items: center;
  }

  .grid {
    width: 100%;
    justify-content: center;
    display: grid;
    grid-template-columns: repeat(auto-fit, min(500px, 90vw) min(500px, 90vw));
    gap: 24px;
  }

  .card {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 5px;
    align-items: center;
    max-width: 500px;
    & img {
      width: min(500px, 90vw);
      height: min(500px, 90vw);
      overflow: hidden;
      object-fit: cover;
    }
    & figcaption {
      display: flex;
      flex-direction: column;
      flex: 1;
      & h3 {
        font-weight: 700;
        font-size: var(--step-3);
        text-align: center;
        line-height: 1.25;
      }
    }
  }

  @media (max-width: 1368px) {
    .grid {
      grid-template-columns: repeat(auto-fit, min(500px, 90vw));
    }
  }
</style>
