---
import Discovery from "../../../public/assets/homePage/OurProcess/discovery.svg";
import Grow from "../../../public/assets/homePage/OurProcess/grow.svg";
import Build from "../../../public/assets/homePage/OurProcess/build.svg";
import Launch from "../../../public/assets/homePage/OurProcess/launch.svg";

import Smudge from "../../../public/assets/homePage/smudge.svg";

const process = [
  {
    title: "Discovery",
    description:
      "We start with a quick call to understand your business, your goals, and how your website can help you get more clients. This step helps us create a clear plan tailored to your needs.",
    outcome: "Clear direction and strategy",
    includedList: [
      "business & service breakdown",
      "target audience understanding",
      "review of your current online presence",
      "goal setting",
    ],
    SVG: Discovery,
  },
  {
    title: "Build",
    description:
      "We design and develop your website from the ground up, focusing on clean design, user experience, and conversion. Everything is built to look professional and turn visitors into bookings.",
    outcome: "A high-quality, conversion-focused website",
    includedList: [
      "custom website design",
      "mobile optimization",
      "booking system integration (Booksy, etc.)",
      "fast and responsive performance",
    ],
    SVG: Build,
  },
  {
    title: "Launch",
    description:
      "Once everything is ready, we launch your website and make sure everything is running smoothly so customers can find and book with you easily.",
    outcome: "Your business is live and accessible online",
    includedList: [
      "full site testing",
      "domain & hosting setup",
      "going live",
      "ensuring booking and contact features work",
    ],
    SVG: Launch,
  },
  {
    title: "Grow",
    description:
      "After launch, we help you improve your online visibility and continue bringing in more clients through SEO and ongoing optimization.",
    outcome: "More traffic, more visibility, more bookings",
    includedList: [
      "local SEO setup (Google visibility)",
      "content improvements",
      "performance tracking",
      "optional monthly support",
    ],
    SVG: Grow,
  },
];
---

<section id="Process-section">
  <div class="header-wrapper">
    <div>
      <Smudge />
      <h2>Our Process</h2>
    </div>
    <p>How It Works</p>
  </div>

  <div class="process-list">
    {
      process.map(
        ({ title, description, includedList, SVG, outcome }, index) => {
          const listNum = index + 1;
          const isEven = listNum % 2 === 0;
          const SvgComponent = SVG;

          return (
            <div class:list={["card", { "card-reverse": isEven }]}>
              <SvgComponent class="process-icon" />

              <div>
                <h3 class="process-title">
                  {listNum}. {title}
                </h3>
                <p>{description}</p>
                <p>What's included</p>
                <ul>
                  {includedList.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
                <p>👉 Outcome: {outcome}</p>
              </div>
            </div>
          );
        },
      )
    }
  </div>
  <h3>
    🌟No technical experience needed — we handle everything from start to
    finish.🌟
  </h3>
</section>

<style>
  h3 {
    font-size: var(--step-2);
    font-weight: 700;
    color: #1e1e1e;
  }
  section {
    padding: min(80px, 10vw);
    align-items: center;
    gap: 120px;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-evenly;
    & > :last-child {
      text-align: center;
    }
  }

  .header-wrapper {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: center;
    & div {
      position: relative;
      & h2 {
        font-size: var(--step-4);
        position: relative;
        margin: 0;
      }
      & svg {
        position: absolute;
        width: calc(var(--step-4) * 5);
        bottom: -15px;
        right: 0;
        left: 20px;
        transform: scale(1.1, 0.9);
        transform-origin: center;
      }
    }
  }

  .process-list {
    max-width: 1300px;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .card {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 12px;
    & svg {
      min-width: min(400px, 50vw);
      width: min(400px, 50vw);
      min-height: min(400px, 50vw);
      height: min(400px, 50vw);
      background-color: white;
      /* display: none; */
    }
    & div {
      display: flex;
      flex-direction: column;
      gap: 8px;
      & ul {
        list-style-position: inside;
        margin-left: -35px;
      }
    }
  }
  .card-reverse {
    flex-direction: row-reverse;
  }

  @media (max-width: 800px) {
    .card {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
</style>
